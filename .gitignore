# ──────────────────────────────────────────────
# .gitignore — Identera Full Stack
# ──────────────────────────────────────────────

# Dependencias
node_modules/
**/node_modules/

# Builds y artefactos
dist/
dist-ssr/
build/
cdk.out/
.aws-sam/build/
*.zip

# Variables de entorno (¡nunca al repo!)
.env
.env.local
.env.*.local
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
.venv/
*.egg-info/
dist/
*.eggs

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Sistema operativo
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Editores
.vscode/*
!.vscode/extensions.json
.idea/

# Uploads locales
backend/uploads/*
!backend/uploads/.gitkeep

# DynamoDB local
docker/dynamodb/*.db

# CDK
infra/cdk.out/
infra/*.js
infra/*.d.ts
!infra/jest.config.js

# Misceláneos
*.local
eslint-report.json
lint.txt
lint_output.txt
